OPENAI_API_KEY=sk-proj-xxxxx

JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_HOURS=8

# Default database mode
# sqlite = stable/default mode, uses DB_PATH
# postgres = PostgreSQL + pgvector mode, uses DATABASE_URL
DB_ENGINE=sqlite

# SQLite config
DB_PATH=./data/chatbot.db

# PostgreSQL config
# Required only when DB_ENGINE=postgres
# Local Docker example:
# DATABASE_URL=postgresql://chatbot:chatbotpass@localhost:5433/chatbot_test
# Test server example:
# DATABASE_URL=postgresql://mi:password@192.168.x.x:5432/chatbot_test
# Production example:
# DATABASE_URL=postgresql://user:password@db-host:5432/chatbot_prod
DATABASE_URL=

SIMILARITY_THRESHOLD=0.6

LLM_MODEL=gpt-4o-mini

EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=1024

CORS_ORIGIN=http://localhost:3002

UPLOAD_DIR=./data/uploads