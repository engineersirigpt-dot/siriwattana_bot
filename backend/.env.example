OPENAI_API_KEY=sk-proj-xxxxx

JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_HOURS=8

# Default database mode
# sqlite = stable/default mode, uses DB_PATH
# postgres = PostgreSQL + pgvector mode, uses DATABASE_URL
DB_ENGINE=sqlite

# SQLite config
DB_PATH=./data/chatbot.db

# PostgreSQL config
# Required only when DB_ENGINE=postgres
# Local Docker example:
# DATABASE_URL=postgresql://chatbot:chatbotpass@localhost:5433/chatbot_test
# Test server example:
# DATABASE_URL=postgresql://mi:password@192.168.x.x:5432/chatbot_test
# Production example:
# DATABASE_URL=postgresql://user:password@db-host:5432/chatbot_prod
DATABASE_URL=

# Thai text typically gets cosine sim ~0.6 for paraphrased questions.
# 0.55 is a good starting point; raise to 0.60+ if false matches appear.
SIMILARITY_THRESHOLD=0.55

LLM_MODEL=gpt-4o-mini

EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=1024

CORS_ORIGIN=http://localhost:3002

UPLOAD_DIR=./data/uploads

# --- MI (Master Information) integration ---
# Optional. When set, the chatbot's /auth/login endpoint accepts MI credentials
# as a fallback after local users fail to authenticate. Leave blank to disable.
# Source view: MI2_AUTHEN.dbo.vw_AUTHEN_user_account (MD5 lowercase passwords).
# Active users are filtered by status = 'ACTIVE'.
# NEVER commit real values for these. Set them in your real .env only.
MI_DB_SERVER=
MI_DB_PORT=1433
MI_DB_USER=
MI_DB_PASSWORD=
MI_DB_NAME=MI2_AUTHEN
MI_CONNECT_TIMEOUT=5
