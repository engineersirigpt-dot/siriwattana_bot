# === PRODUCTION environment template (Sirivatana Chatbot) ===
#
# Copy this file to backend/.env.prod on the server, then fill in real secrets.
# DO NOT commit backend/.env.prod to git (it's already gitignored via .env.*).
#
# Generate secrets:
#   JWT_SECRET     : python -c "import secrets; print(secrets.token_urlsafe(48))"
#   POSTGRES_PASS  : python -c "import secrets; print(secrets.token_urlsafe(24))"
#
# Quick sanity:
#   - JWT_SECRET must differ from test (and >= 32 chars) so test tokens cannot reach prod
#   - POSTGRES_PASSWORD must match docker-compose.prod.yml's ${POSTGRES_PASSWORD}

# --- OpenAI ---
OPENAI_API_KEY=<paste-real-key>

# --- JWT (DIFFERENT from test) ---
JWT_SECRET=<paste-new-48-char-secret>
JWT_EXPIRES_HOURS=8

# --- Database: PostgreSQL + pgvector (prod) ---
# In Docker network, backend reaches postgres via service name "postgres".
# Outside Docker, use 127.0.0.1:5434
DB_ENGINE=postgres
DATABASE_URL=postgresql://chatbot:<prod-postgres-password>@postgres:5432/chatbot_prod

# Also set POSTGRES_PASSWORD for docker-compose.prod.yml. Easiest: export before launch:
#   POSTGRES_PASSWORD=<same-as-above> sudo docker compose -f docker-compose.prod.yml up -d

# --- RAG / Embedding ---
SIMILARITY_THRESHOLD=0.55
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=1024

# --- CORS (RESTRICT to actual prod URL only — no wide-open LAN) ---
CORS_ORIGINS=http://192.168.5.32:3031

# --- Uploads ---
UPLOAD_DIR=./data/uploads
