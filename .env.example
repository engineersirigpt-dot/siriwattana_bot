# ===== Root .env (read by docker-compose) =====
# Copy this file to .env and fill in actual values. Never commit real .env.

# --- Postgres (REQUIRED when running docker compose) ---
# Used by both the postgres service and the backend DATABASE_URL.
POSTGRES_PASSWORD=change-me-to-strong-random-password

# --- Public host config ---
# Leave at localhost for local dev. Set to LAN IP / domain for test server.
HOST_IP=localhost
FRONTEND_PORT=3000
BACKEND_PORT=8000

# Test server example (uncomment + adjust):
# HOST_IP=192.168.5.32
# FRONTEND_PORT=3032
# BACKEND_PORT=8000

# ===== Backend secrets are configured in backend/.env =====
# See backend/.env.example for the full list.
